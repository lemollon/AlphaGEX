# SpreadWorks Environment Variables
# Copy to .env and fill in actual values
#
# SECURITY: NEVER commit a real .env file. The repo's .gitignore already
# excludes .env / .env.local — keep it that way. Anyone with these tokens
# can take over the bot, post in your channel, or drain your broker
# account. Public scanners (E.O.S., GitHub secret scanning, others) sweep
# repos within minutes of a push and weaponize leaked webhooks.
# If you ever leak any of these:
#   - Discord webhook  -> delete the webhook in Discord and create a new one
#   - Discord token    -> regenerate via Discord Developer Portal
#   - TRADIER_TOKEN    -> rotate at developer.tradier.com
#   - ANTHROPIC_API_KEY-> rotate at console.anthropic.com

# ============================================================================
# TRADIER (REQUIRED - options chain data and order execution)
# ============================================================================
TRADIER_TOKEN=your_tradier_api_token
TRADIER_ACCOUNT_ID=your_tradier_account_id

# ============================================================================
# ALPHAGEX INTEGRATION (REQUIRED - GEX data from AlphaGEX backend)
# ============================================================================
ALPHAGEX_BASE_URL=https://your-alphagex-backend.onrender.com

# ============================================================================
# DISCORD BOT (REQUIRED for bot/ service)
# ============================================================================
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_discord_server_guild_id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# ============================================================================
# FRONTEND (set in Vite / Render static site env)
# ============================================================================
VITE_API_URL=http://localhost:8000

# ============================================================================
# BACKEND
# ============================================================================
FRONTEND_URL=http://localhost:5173
