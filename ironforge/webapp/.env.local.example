# PostgreSQL (Render internal URL)
DATABASE_URL=postgresql://user:password@host:5432/ironforge

# Tradier API (primary key used for market data quotes)
TRADIER_API_KEY=your_tradier_sandbox_key
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Three sandbox accounts for FLAME trade mirroring
# Each account gets the same trades mirrored simultaneously
TRADIER_SANDBOX_KEY_USER=your_sandbox_key
TRADIER_SANDBOX_KEY_MATT=matts_sandbox_key
TRADIER_SANDBOX_KEY_LOGAN=logans_sandbox_key
