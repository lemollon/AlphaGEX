# Force install of devDependencies during the build even when NODE_ENV=production.
# Render (and any host) sets NODE_ENV=production, which makes `npm install` omit
# devDependencies — but the build NEEDS them (typescript, tailwindcss, postcss,
# autoprefixer, @types/*). Without `typescript` installed, Next.js cannot read
# tsconfig.json, so the `@/*` path alias is never registered and every `@/...`
# import fails with "Module not found". `include=dev` overrides the implicit omit.
include=dev
