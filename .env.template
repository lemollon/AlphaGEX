# AlphaGEX Configuration
# Copy this to .env and fill in your actual values
#
# PRODUCTION CHECKLIST:
# [ ] DATABASE_URL - PostgreSQL connection string
# [ ] TRADIER_API_KEY - For options quotes and orders
# [ ] POLYGON_API_KEY - For VIX and historical data
# [ ] TRADING_VOLATILITY_API_TOKEN - For GEX data (v2 Bearer token, REQUIRED as of Apr 2026)
# [ ] NEXT_PUBLIC_API_URL (Vercel) - Backend URL

# ============================================================================
# DATABASES (REQUIRED)
# ============================================================================

# Main AlphaGEX database (for GEX data, trades, positions)
DATABASE_URL=postgresql://user:password@host:5432/alphagex

# ORAT Options Database (Optional - for KRONOS backtester)
# Falls back to DATABASE_URL if not set
ORAT_DATABASE_URL=postgresql://user:password@host:5432/orat_db

# ============================================================================
# API KEYS (REQUIRED)
# ============================================================================

# Trading Volatility API - GEX data source
# Get from: https://www.tradingvolatility.net/
#
# v2 Bearer token (REQUIRED as of Jan 2026 — TV deprecated v1 query-param auth).
# This is the Stripe-style subscription identifier (sub_xxx) shown on your TV
# account billing page. Used as `Authorization: Bearer <token>` against the v2 API
# at https://stocks.tradingvolatility.net/api/v2.
TRADING_VOLATILITY_API_TOKEN=sub_your_v2_bearer_token_here

# Optional: override the default v2 base URL (rarely needed)
# TRADING_VOLATILITY_V2_BASE_URL=https://stocks.tradingvolatility.net/api/v2

# Legacy v1 username (no longer used by AlphaGEX after v2 migration; safe to leave
# unset). Kept here for reference in case you need to identify your TV account.
# TRADING_VOLATILITY_API_KEY=your_legacy_v1_username

# Polygon.io API - VIX and historical market data
# Get from: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Tradier API - Options quotes and order execution
# Get from: https://developer.tradier.com/
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_ACCOUNT_ID=your_account_id_here

# ============================================================================
# TRADING MODE
# ============================================================================

# Set to 'true' for paper trading, 'false' for live trading
TRADIER_SANDBOX=true

# Sandbox credentials (different from production!)
# Get sandbox keys from: https://developer.tradier.com/user/applications
TRADIER_SANDBOX_API_KEY=your_sandbox_api_key_here
TRADIER_SANDBOX_ACCOUNT_ID=your_sandbox_account_id_here

# Additional sandbox accounts for FORTRESS trade mirroring (optional)
# FORTRESS mirrors trades to these accounts automatically
TRADIER_FORTRESS_SANDBOX_API_KEY_2=
TRADIER_FORTRESS_SANDBOX_ACCOUNT_ID_2=
TRADIER_FORTRESS_SANDBOX_API_KEY_3=
TRADIER_FORTRESS_SANDBOX_ACCOUNT_ID_3=

# ============================================================================
# AI FEATURES (OPTIONAL)
# ============================================================================

# Anthropic Claude API - AI trade explanations and copilot
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=development

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ============================================================================
# PUSH NOTIFICATIONS (OPTIONAL)
# ============================================================================

# Generate VAPID keys: npx web-push generate-vapid-keys
ENABLE_PUSH_NOTIFICATIONS=false
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ============================================================================
# FRONTEND (VERCEL) - Set these in Vercel dashboard
# ============================================================================

# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
# NEXT_PUBLIC_WS_URL=wss://your-backend.onrender.com/ws
