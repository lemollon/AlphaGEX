# Databricks SQL connection
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxx.x.azuredatabricks.net
DATABRICKS_WAREHOUSE_ID=your_warehouse_id
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxx

# Unity Catalog (defaults shown)
DATABRICKS_CATALOG=alpha_prime
DATABRICKS_SCHEMA=ironforge

# Tradier API (for live position monitoring / MTM quotes)
TRADIER_API_KEY=your_tradier_api_key
TRADIER_BASE_URL=https://api.tradier.com/v1
